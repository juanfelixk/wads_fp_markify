generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  LECTURER
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  REVISED
  GRADED
  SUBMITTED_LATE
  TO_BE_REVIEWED
}

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String   @unique
  emailVerified   Boolean  @default(false)
  image           String?
  role            Role     @default(STUDENT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  lecturerClasses Class[]      @relation("LecturerClasses")
  enrollments     Enrollment[] @relation("StudentEnrollments")
  submissions     Submission[] @relation("StudentSubmissions")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  institution String   @default("BINUS University International")

  classes     Class[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Class {
  id            String   @id @default(cuid())
  code          String
  academicYear  String
  enrollmentKey String

  courseId      String
  course        Course       @relation(fields: [courseId], references: [id])
  lecturerId    String
  lecturer      User         @relation("LecturerClasses", fields: [lecturerId], references: [id])
  enrollments   Enrollment[]
  assignments   Assignment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([courseId, code, academicYear])
  @@index([courseId])
  @@index([lecturerId])
}

model Enrollment {
  id        String   @id @default(cuid())
  studentId String
  classId   String

  student   User     @relation("StudentEnrollments", fields: [studentId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([studentId, classId])
  @@index([studentId])
  @@index([classId])
}

model Assignment {
  id           String   @id @default(cuid())
  title        String
  instructions String?
  maxPoints    Int?
  rubric       Json?
  lateAllowed Boolean? @default(false)

  classId      String
  class        Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions  Submission[]

  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([classId])
}

model Submission {
  id           String           @id @default(cuid())
  status       SubmissionStatus @default(NOT_SUBMITTED)
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  aiScore      Int?
  finalScore   Int?
  comment      String?
  aiGrammarFeedback    Json?   // stores grammar & style analysis results
  aiStructureFeedback  Json?   // stores essay structure evaluation results

  assignmentId String
  assignment   Assignment         @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User               @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  versions     SubmissionVersion[]
  annotations  SubmissionAnnotation[]
  criterionScores SubmissionCriterionScore[]

  submittedAt  DateTime?
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// tracks every file upload for a submission for full revision history
model SubmissionVersion {
  id           String   @id @default(cuid())
  version      Int
  fileUrl      String
  fileName     String
  fileSize     Int
  uploadedAt   DateTime @default(now())

  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
}

model SubmissionAnnotation {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  page         Int       // which page the annotation is on
  x            Float     // position (percentage-based for responsiveness)
  y            Float
  width        Float?    // for highlight/box annotations
  height       Float?
  content      String    // the feedback text
  type         AnnotationType
  quote String?
  source       AnnotationSource @default(AI)  // AI or LECTURER

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([submissionId])
}

enum AnnotationType {
  PRAISE
  SUGGESTION
  ISSUE
}

enum AnnotationSource {
  AI
  LECTURER
}

model SubmissionCriterionScore {
  id             String     @id @default(cuid())
  submissionId   String
  submission     Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  criterionName  String     // matches RubricCriterion.name
  pointsAwarded  Int
  pointsMax      Int
  rationale      String     // AI's 1-2 sentence justification

  @@unique([submissionId, criterionName])
  @@index([submissionId])
}